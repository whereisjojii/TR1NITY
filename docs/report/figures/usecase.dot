digraph UseCase {
    graph [rankdir=LR, splines=spline, bgcolor="white", fontname="Helvetica", nodesep=0.4, ranksep=1.0, pad="0.3"];
    node  [fontname="Helvetica", fontsize=10, fontcolor="#0D47A1"];
    edge  [color="#1565C0", penwidth=1.0, arrowhead=none];

    /* Actors (left) */
    {
        node [shape=none, label="", image=""];
        analyst [label="Security Analyst\n(Hamza / Irtaza /\nHammad)", shape=plaintext, fontsize=11, fontcolor="#0D47A1"];
        attacker [label="Adversary\n(External)", shape=plaintext, fontsize=11, fontcolor="#0D47A1"];
    }

    /* Actor stick figures via record nodes */
    analyst_fig [shape=circle, label="", width=0.35, color="#0D47A1", style="filled", fillcolor="#0D47A1"];
    attacker_fig [shape=circle, label="", width=0.35, color="#0D47A1", style="filled", fillcolor="#0D47A1"];

    analyst -> analyst_fig [style=invis];
    attacker -> attacker_fig [style=invis];

    /* System boundary cluster (TR1NITY) */
    subgraph cluster_system {
        label="TR1NITY  —  Unified SIEM Correlation Platform";
        style="rounded"; color="#0D47A1"; fontname="Helvetica-Bold"; fontsize=12; fontcolor="#0D47A1";
        margin=18;

        node [shape=ellipse, style="filled,rounded", color="#1976D2", fillcolor="#E3F2FD", fontcolor="#0D47A1", penwidth=1.2, height=0.65, width=2.0];

        UC1 [label="UC-1\nIngest unified logs\n(Wazuh / Firewall / WAF)"];
        UC2 [label="UC-2\nCorrelate cross-source\nincidents"];
        UC3 [label="UC-3\nMark alert as\nfalse positive"];
        UC4 [label="UC-4\nDeploy SIGMA rule\nfrom community library"];
        UC5 [label="UC-5\nInvestigate incident\n(single-pane cockpit)"];
        UC6 [label="UC-6\nGenerate post-incident\nreport (AI-drafted)"];
        UC7 [label="UC-7\nView ATT&CK coverage\nheatmap"];
        UC8 [label="UC-8\nGenerate compliance\nPDF report"];
        UC9 [label="UC-9\nReceive auto-enriched\nalert (threat intel)"];
        UC10 [label="UC-10\nExport / restore\nbackup"];
    }

    /* Connections */
    analyst_fig -> UC2;
    analyst_fig -> UC3;
    analyst_fig -> UC4;
    analyst_fig -> UC5;
    analyst_fig -> UC6;
    analyst_fig -> UC7;
    analyst_fig -> UC8;
    analyst_fig -> UC10;

    attacker_fig -> UC1 [label=" triggers ", fontsize=9, fontcolor="#1565C0"];
    attacker_fig -> UC2 [label=" triggers ", fontsize=9, fontcolor="#1565C0"];
    attacker_fig -> UC9 [label=" triggers ", fontsize=9, fontcolor="#1565C0"];
}
