digraph TR1NITY {
    graph [rankdir=TB, splines=spline, nodesep=0.55, ranksep=0.85, bgcolor="white", fontname="Helvetica", pad="0.4", margin="0.3", size="6.5,9.5!"];
    node  [fontname="Helvetica", fontsize=14, style="filled,rounded", shape=box, color="#0D47A1", fillcolor="#E3F2FD", fontcolor="#0D47A1", penwidth=1.6, height=0.75, width=2.0];
    edge  [color="#1565C0", fontname="Helvetica", fontsize=11, fontcolor="#1565C0", penwidth=1.2, arrowsize=0.8];

    /* ============== SOURCE LAYER ============== */
    subgraph cluster_sources {
        label="Source Layer  —  Endpoints, Network, Apps";
        style="rounded,filled"; color="#90CAF9"; fillcolor="#F5FAFE"; fontcolor="#0D47A1"; fontname="Helvetica-Bold"; fontsize=14; margin=16;
        wazuh_agent [label="Wazuh Agent\n(HIDS / FIM / Logs)"];
        firewall    [label="Firewall\niptables / pfSense"];
        waf         [label="WAF\nModSecurity / CRS"];
        suricata    [label="Suricata NIDS\n(EVE JSON, optional)"];
    }

    /* ============== INGESTION LAYER ============== */
    subgraph cluster_ingest {
        label="Ingestion & Normalization (Module 1)";
        style="rounded,filled"; color="#64B5F6"; fillcolor="#E8F1FB"; fontcolor="#0D47A1"; fontname="Helvetica-Bold"; fontsize=14; margin=16;
        ingestor [label="ingestor (FastAPI)\nWebhook + Syslog +\nFilebeat receivers", fillcolor="#BBDEFB"];
        schema   [label="ECS Common Schema\n(unified JSON)", fillcolor="#BBDEFB"];
        ingestor -> schema [label=" normalize "];
    }

    /* ============== STORAGE ============== */
    subgraph cluster_storage {
        label="Storage & Search";
        style="rounded,filled"; color="#42A5F5"; fillcolor="#E1EEFA"; fontcolor="#0D47A1"; fontname="Helvetica-Bold"; fontsize=14; margin=16;
        indexer  [label="Wazuh Indexer\n(OpenSearch)\ntr1nity-events-*", fillcolor="#90CAF9"];
        postgres [label="PostgreSQL\nCases, Audit,\nFP feedback", fillcolor="#90CAF9"];
        chroma   [label="ChromaDB\nRAG vectors", fillcolor="#90CAF9"];
    }

    /* ============== BRAIN ============== */
    subgraph cluster_brain {
        label="The Brain (Module 2)  —  Correlation, Enrichment, FP Reduction (Module 4)";
        style="rounded,filled"; color="#1E88E5"; fillcolor="#DDE9F8"; fontcolor="#0D47A1"; fontname="Helvetica-Bold"; fontsize=14; margin=16;
        correlator [label="correlator (FastAPI)\nTemporal grouping +\nentity resolution +\nATT&CK tagging", fillcolor="#64B5F6", fontcolor="white"];
        ti         [label="Threat Intel\nAbuseIPDB / OTX /\nNVD / abuse.ch", fillcolor="#64B5F6", fontcolor="white"];
        sigma      [label="SIGMA Manager\npySigma → DSL\n3,000+ rules", fillcolor="#64B5F6", fontcolor="white"];
        fp         [label="FP Layers\nWhitelist + sklearn\nclassifier + suppress", fillcolor="#64B5F6", fontcolor="white"];
    }

    /* ============== AI ASSIST ============== */
    subgraph cluster_ai {
        label="AI Assist  (Module 3)  —  Async, Human-In-The-Loop";
        style="rounded,filled"; color="#1976D2"; fillcolor="#D6E2F2"; fontcolor="#0D47A1"; fontname="Helvetica-Bold"; fontsize=14; margin=16;
        ai     [label="ai-assist (FastAPI)\nllama.cpp + Vulkan", fillcolor="#1976D2", fontcolor="white"];
        llm    [label="Foundation-Sec-8B\nQ4_K_M  (~5 GB)\nlocal LLM", fillcolor="#1976D2", fontcolor="white"];
        rag    [label="RAG Knowledge\nATT&CK + NVD +\nSigmaHQ + Runbooks", fillcolor="#1976D2", fontcolor="white"];
        ai -> llm;
        ai -> rag;
    }

    /* ============== UI / API ============== */
    subgraph cluster_ui {
        label="Analyst Workstation (Module 5)  —  Single-pane Cockpit";
        style="rounded,filled"; color="#0D47A1"; fillcolor="#CCD9EC"; fontcolor="#0D47A1"; fontname="Helvetica-Bold"; fontsize=14; margin=16;
        api  [label="api (FastAPI)\nREST + WebSocket", fillcolor="#0D47A1", fontcolor="white"];
        ui   [label="React + Tailwind\n+ shadcn/ui\nAlert queue, ATT&CK\nheatmap, cases", fillcolor="#0D47A1", fontcolor="white"];
        api -> ui [label=" WS push ", color="#0D47A1", fontcolor="#0D47A1"];
    }

    /* ============== REPORTING ============== */
    reporting [label="Reporting (Module 6)\nCompliance PDFs +\nWeekly metrics +\nBackup / Restore", fillcolor="#E3F2FD", color="#0D47A1"];

    /* ============== ARROWS ============== */
    wazuh_agent -> ingestor [label=" alerts "];
    firewall    -> ingestor [label=" syslog "];
    waf         -> ingestor [label=" CEF / JSON "];
    suricata    -> ingestor [label=" EVE JSON "];

    schema    -> indexer    [label=" write "];
    indexer   -> correlator [label=" poll 30s "];
    correlator -> ti        [label=" enrich "];
    correlator -> sigma     [label=" match "];
    correlator -> fp        [label=" score "];
    correlator -> indexer   [label=" incidents "];

    correlator -> ai        [label=" async tasks ", style=dashed];
    ai         -> postgres  [label=" drafts ", style=dashed];

    api -> indexer  [label=" query "];
    api -> postgres [label=" cases / audit "];
    api -> chroma   [label=" similar incidents "];
    api -> ai       [label=" draft requests ", style=dashed];

    api -> reporting [label=" weekly "];
    correlator -> chroma [label=" embed cases ", style=dotted];
}
