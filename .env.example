# TR1NITY environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# All secrets / API keys are FREE-tier; no paid APIs are required.
# See docs/planning/03-build-pathway.md (Section 1) for the audited free-tier table.

# -------- Core --------
TR1NITY_ENV=dev                        # dev | prod
TR1NITY_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# -------- OpenSearch / Wazuh Indexer --------
OPENSEARCH_HOST=wazuh-indexer
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=ChangeMeAtFirstBoot!
OPENSEARCH_VERIFY_TLS=false            # dev only

# -------- PostgreSQL (cases, audit, FP feedback) --------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tr1nity
POSTGRES_USER=tr1nity
POSTGRES_PASSWORD=ChangeMeAtFirstBoot!

# -------- AI Assist (LLM) --------
# Set to "true" to bypass Foundation-Sec-8B and use deterministic templates
# (recommended on machines without a Vulkan-capable GPU).
MOCK_LLM=true
LLM_MODEL_PATH=/models/foundation-sec-8b-instruct.Q4_K_M.gguf
LLM_BACKEND=vulkan                     # vulkan | cuda | cpu
LLM_THREADS=4
LLM_CTX_SIZE=8192

# -------- Threat-intel APIs (ALL FREE TIER) --------
# AbuseIPDB free tier: 1,000 IP checks/day, 100 block-list checks/day, no credit card
# https://www.abuseipdb.com/account/api  (free signup)
ABUSEIPDB_API_KEY=

# AlienVault OTX free tier: rate-limited per minute, no daily cap
# https://otx.alienvault.com/api  (free signup)
OTX_API_KEY=

# NVD CVE API v2 — optional API key raises rate limit from 5 req/30s to 50 req/30s
# https://nvd.nist.gov/developers/request-an-api-key  (free)
NVD_API_KEY=

# MaxMind GeoLite2 license key (free monthly DB)
# https://www.maxmind.com/en/geolite2/signup  (free)
MAXMIND_LICENSE_KEY=

# -------- TR1NITY service ports (host bindings) --------
TR1NITY_API_PORT=8000
TR1NITY_INGESTOR_PORT=8001
TR1NITY_CORRELATOR_PORT=8002
TR1NITY_AI_ASSIST_PORT=8003

# -------- API auth (self-hosted) --------
TR1NITY_API_JWT_SECRET=change-me-to-a-random-32-char-string-min
TR1NITY_API_KEY=                       # optional simple API key for service-to-service

# -------- Retention / lifecycle (defaults) --------
EVENT_HOT_DAYS=7
EVENT_WARM_DAYS=30
EVENT_COLD_CLOSE_DAYS=90
EVENT_DELETE_DAYS=180
INCIDENT_RETENTION_DAYS=365
