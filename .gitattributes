# Force LF line endings on every checkout, regardless of platform.
#
# Why: TR1NITY's CI uses pre-commit hooks (mixed-line-ending --fix=lf,
# ruff-format) that fail when files have CRLF. Without this file, Git on
# Windows applies its default `core.autocrlf=true`, converting LF -> CRLF
# at checkout, which trips the hooks.
#
# Pattern is read top-to-bottom; later rules override earlier ones for
# the same path.

# Default: every text file uses LF in the working copy on every OS.
# Git auto-detects text vs binary; binary stays untouched.
* text=auto eol=lf

# Source code — explicitly text/LF
*.py     text eol=lf
*.pyi    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
*.bash   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf

# Special files
Dockerfile      text eol=lf
Makefile        text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
.editorconfig   text eol=lf
.env.example    text eol=lf

# Binary — never normalize
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    text eol=lf
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.zip    binary
*.tar    binary
*.tar.gz binary
*.tgz    binary
*.gz     binary
*.bz2    binary
*.xz     binary
*.7z     binary
*.pdf    binary
*.exe    binary
*.dll    binary
*.so     binary
*.dylib  binary
*.pyc    binary
*.pyo    binary

# Lockfiles — text but never auto-modify
package-lock.json text eol=lf -diff
pnpm-lock.yaml    text eol=lf -diff
yarn.lock         text eol=lf -diff
poetry.lock       text eol=lf -diff
uv.lock           text eol=lf -diff
